# Copy this file to your local environment setup and replace placeholder values.
# Do not commit real secrets.

# Filesystem MCP root
OPENCODE_FILESYSTEM_ROOT=C:\\Users\\YourName

# GitHub MCP
GITHUB_PAT=your_github_pat_here

# Brave MCP / API
BRAVE_API_KEY=your_brave_api_key_here

# Obsidian-compatible notes MCP
OBSIDIAN_API_KEY=your_notes_api_key_here
OBSIDIAN_BASE_URL=http://127.0.0.1:<port>

# Chroma MCP
CHROMA_DB_PATH=C:\\path\\to\\chroma-db

# AnySearch MCP
ANYSEARCH_API_KEY=your_anysearch_api_key_here

# Local KB MCP
KB_PYTHON=C:\\path\\to\\python.exe
KB_MCP_SERVER=C:\\path\\to\\kb\\scripts\\mcp_server.py
KB_ROOT=C:\\path\\to\\kb
KB_CONFIG=C:\\path\\to\\kb\\config\\kb.yaml
